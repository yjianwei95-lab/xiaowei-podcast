# ============ 数据库（本地 SQLite，零外网依赖） ============
# 数据库文件路径；不填则默认项目根目录 data.db（Cloud Studio 工作区自包含）
DB_PATH=./data.db
SESSION_SECRET=随便一串随机字符串

# ============ 运营后台账号（admins 表，启动自动初始化） ============
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
# 运营后台独立会话密钥
OPS_SESSION_SECRET=随便另一串随机字符串
OPS_PORT=4000

# ============ QQ 邮箱 SMTP（用于注册邮箱验证） ============
# QQ 邮箱地址（用作发信人）
QQ_EMAIL=你的QQ邮箱@qq.com
# QQ 邮箱「授权码」——在 邮箱设置→账户→开启SMTP服务 后获取，注意不是 QQ 登录密码
QQ_AUTH_CODE=你的QQ邮箱授权码

# ============ 站点 ============
PORT=3000
