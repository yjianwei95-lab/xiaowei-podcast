# ============ 数据库（Supabase） ============
SUPABASE_URL=你的Supabase项目URL
SUPABASE_ANON_KEY=你的Supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=你的Supabase_service_role_key
SESSION_SECRET=随便一串随机字符串

# ============ QQ 邮箱 SMTP（用于注册邮箱验证） ============
# QQ 邮箱地址（用作发信人）
QQ_EMAIL=你的QQ邮箱@qq.com
# QQ 邮箱「授权码」——在 邮箱设置→账户→开启SMTP服务 后获取，注意不是 QQ 登录密码
QQ_AUTH_CODE=你的QQ邮箱授权码

# ============ 站点 ============
PORT=3000
