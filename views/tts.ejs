<div class="tts-workspace">

<style>
/* ========== TTS 内部样式（scoped 在 .tts-workspace 下） ========== */
.tts-workspace * { margin: 0; padding: 0; box-sizing: border-box; }
.tts-workspace { font-family: -apple-system, 'Inter', 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif; color: #1F2937; }

.tts-workspace .main { max-width: 1100px; margin: 0 auto; padding: 20px 0 40px; display: grid; grid-template-columns: 1fr 340px; gap: 20px; }
.tts-workspace .col-left { display: flex; flex-direction: column; gap: 16px; }
.tts-workspace .col-right { display: flex; flex-direction: column; gap: 16px; }

.tts-workspace .card { background: #fff; border-radius: 12px; padding: 20px 24px; border: 1px solid #E5E7EB; }
.tts-workspace .card-title { font-size: 14px; font-weight: 600; margin-bottom: 14px; display: flex; align-items: center; gap: 6px; }

.tts-workspace .template-chips { display: flex; gap: 8px; flex-wrap: wrap; }
.tts-workspace .chip { padding: 5px 12px; border-radius: 16px; border: 1px solid #E5E7EB; background: #F9FAFB; font-size: 12px; cursor: pointer; color: #4B5563; white-space: nowrap; transition: all .15s; }
.tts-workspace .chip:hover { border-color: #6366F1; color: #6366F1; background: #EEF2FF; }

.tts-workspace .text-input { width: 100%; min-height: 140px; border: 1px solid #E5E7EB; border-radius: 8px; padding: 14px; font-size: 14px; font-family: inherit; resize: vertical; outline: none; line-height: 1.8; background: #FAFBFC; }
.tts-workspace .text-input:focus { border-color: #6366F1; background: #fff; }
.tts-workspace .char-row { display: flex; justify-content: space-between; align-items: center; margin-top: 8px; flex-wrap: wrap; gap: 8px; }
.tts-workspace .char-info { font-size: 12px; color: #9CA3AF; display: flex; gap: 12px; align-items: center; }
.tts-workspace .char-info strong { color: #4B5563; }
.tts-workspace .btn-split { padding: 5px 12px; border-radius: 14px; border: 1px solid #D1D5DB; background: #fff; font-size: 12px; cursor: pointer; color: #6366F1; display: flex; align-items: center; gap: 4px; transition: all .15s; }
.tts-workspace .btn-split:hover { border-color: #6366F1; background: #EEF2FF; }

.tts-workspace .controls { display: flex; gap: 20px; flex-wrap: wrap; align-items: flex-end; }
.tts-workspace .control-group { display: flex; flex-direction: column; gap: 4px; }
.tts-workspace .control-group label { font-size: 11px; color: #9CA3AF; font-weight: 500; text-transform: uppercase; letter-spacing: .5px; }
.tts-workspace .voice-row { display: flex; gap: 6px; align-items: center; }
.tts-workspace .voice-row select { padding: 8px 10px; border: 1px solid #E5E7EB; border-radius: 6px; font-size: 13px; outline: none; background: #FAFBFC; min-width: 180px; }
.tts-workspace .voice-row select:focus { border-color: #6366F1; }
.tts-workspace .btn-preview { width: 32px; height: 32px; border-radius: 50%; border: 1px solid #D1D5DB; background: #fff; cursor: pointer; font-size: 13px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; transition: all .15s; }
.tts-workspace .btn-preview:hover { border-color: #6366F1; background: #EEF2FF; }
.tts-workspace .btn-preview.playing { background: #6366F1; border-color: #6366F1; }
.tts-workspace .slider-row { display: flex; align-items: center; gap: 8px; }
.tts-workspace .slider-row input[type="range"] { width: 100px; accent-color: #6366F1; }
.tts-workspace .slider-row .val { font-size: 12px; color: #6B7280; min-width: 34px; text-align: right; font-variant-numeric: tabular-nums; }

.tts-workspace .btn-generate { width: 100%; height: 46px; border: none; border-radius: 8px; background: linear-gradient(135deg, #6366F1, #8B5CF6); color: #fff; font-size: 15px; font-weight: 600; cursor: pointer; transition: all .2s; display: flex; align-items: center; justify-content: center; gap: 8px; }
.tts-workspace .btn-generate:hover { transform: translateY(-1px); box-shadow: 0 4px 12px rgba(99,102,241,.35); }
.tts-workspace .btn-generate:disabled { background: #D1D5DB; cursor: not-allowed; transform: none; box-shadow: none; }
.tts-workspace .btn-generate .spinner { width: 18px; height: 18px; border: 2px solid #fff; border-top-color: transparent; border-radius: 50%; animation: tts-spin .6s linear infinite; display: none; }
.tts-workspace .btn-generate.progress .spinner { display: block; }
.tts-workspace .btn-generate.progress .btn-text { display: none; }
@keyframes tts-spin { to { transform: rotate(360deg); } }

.tts-workspace .player { display: none; flex-direction: column; gap: 10px; }
.tts-workspace .player.visible { display: flex; }
.tts-workspace .player-bar { display: flex; align-items: center; gap: 10px; background: #F9FAFB; border-radius: 8px; padding: 10px 14px; border: 1px solid #E5E7EB; }
.tts-workspace .btn-play { width: 36px; height: 36px; border-radius: 50%; border: none; background: #6366F1; color: #fff; cursor: pointer; font-size: 14px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; }
.tts-workspace .progress-wrap { flex: 1; height: 5px; background: #E5E7EB; border-radius: 3px; cursor: pointer; position: relative; }
.tts-workspace .progress-fill { height: 100%; background: #6366F1; border-radius: 3px; width: 0%; }
.tts-workspace .player-time { font-size: 11px; color: #6B7280; min-width: 75px; text-align: right; font-variant-numeric: tabular-nums; }
.tts-workspace .player-actions { display: flex; gap: 6px; }
.tts-workspace .btn-action { padding: 7px 16px; border: none; border-radius: 6px; font-size: 12px; cursor: pointer; font-weight: 500; display: flex; align-items: center; gap: 4px; }
.tts-workspace .btn-download { background: #10B981; color: #fff; }
.tts-workspace .btn-download:hover { background: #059669; }
.tts-workspace .btn-save-history { background: #F3F4F6; color: #4B5563; border: 1px solid #E5E7EB; }
.tts-workspace .btn-save-history:hover { background: #E5E7EB; }

.tts-workspace .sentence-panel { display: none; flex-direction: column; gap: 6px; }
.tts-workspace .sentence-panel.visible { display: flex; }
.tts-workspace .sentence-panel-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px; }
.tts-workspace .btn-batch { padding: 6px 14px; border-radius: 6px; border: 1px solid #6366F1; background: #EEF2FF; color: #6366F1; font-size: 12px; cursor: pointer; font-weight: 500; }
.tts-workspace .btn-batch:hover { background: #6366F1; color: #fff; }
.tts-workspace .btn-batch:disabled { border-color: #D1D5DB; background: #F3F4F6; color: #9CA3AF; cursor: not-allowed; }
.tts-workspace .sentence-item { display: flex; align-items: center; gap: 8px; padding: 8px 10px; border-radius: 6px; background: #F9FAFB; border: 1px solid #F3F4F6; font-size: 13px; }
.tts-workspace .sentence-item:hover { border-color: #E5E7EB; }
.tts-workspace .sentence-item .idx { font-size: 11px; color: #9CA3AF; min-width: 24px; text-align: center; }
.tts-workspace .sentence-item .txt { flex: 1; line-height: 1.5; max-height: 40px; overflow: hidden; }
.tts-workspace .sentence-item .s-actions { display: flex; gap: 4px; flex-shrink: 0; }
.tts-workspace .sentence-item .s-btn { width: 28px; height: 28px; border-radius: 50%; border: 1px solid #E5E7EB; background: #fff; cursor: pointer; font-size: 12px; display: flex; align-items: center; justify-content: center; color: #6B7280; }
.tts-workspace .sentence-item .s-btn:hover { border-color: #6366F1; color: #6366F1; }
.tts-workspace .sentence-item .s-btn.play-btn { background: #EEF2FF; border-color: #C7D2FE; color: #6366F1; }
.tts-workspace .sentence-item.status-done .idx { color: #10B981; font-weight: 600; }
.tts-workspace .sentence-item.status-generating .idx { animation: tts-pulse 1s infinite; }
@keyframes tts-pulse { 0%,100% { opacity: 1; } 50% { opacity: .3; } }

.tts-workspace .history-list { display: flex; flex-direction: column; gap: 6px; max-height: 480px; overflow-y: auto; }
.tts-workspace .history-item { display: flex; align-items: center; gap: 8px; padding: 10px; border-radius: 8px; background: #F9FAFB; border: 1px solid #F3F4F6; cursor: pointer; transition: all .15s; }
.tts-workspace .history-item:hover { border-color: #E5E7EB; }
.tts-workspace .history-item .h-info { flex: 1; min-width: 0; }
.tts-workspace .history-item .h-text { font-size: 12px; color: #374151; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.tts-workspace .history-item .h-meta { font-size: 11px; color: #9CA3AF; margin-top: 2px; }
.tts-workspace .history-item .h-actions { display: flex; gap: 4px; flex-shrink: 0; }
.tts-workspace .history-item .h-btn { width: 26px; height: 26px; border-radius: 50%; border: 1px solid #E5E7EB; background: #fff; cursor: pointer; font-size: 11px; display: flex; align-items: center; justify-content: center; color: #6B7280; }
.tts-workspace .history-item .h-btn:hover { border-color: #6366F1; color: #6366F1; }
.tts-workspace .history-item .h-btn.danger:hover { border-color: #EF4444; color: #EF4444; }
.tts-workspace .history-empty { text-align: center; padding: 24px; color: #9CA3AF; font-size: 13px; }
.tts-workspace .history-clear { text-align: right; margin-bottom: 8px; }
.tts-workspace .history-clear button { font-size: 11px; color: #9CA3AF; background: none; border: none; cursor: pointer; }
.tts-workspace .history-clear button:hover { color: #EF4444; }

.tts-workspace .toast { position: fixed; bottom: 32px; left: 50%; transform: translateX(-50%); padding: 10px 22px; border-radius: 8px; font-size: 13px; z-index: 200; transition: all .25s; opacity: 0; pointer-events: none; box-shadow: 0 4px 12px rgba(0,0,0,.1); }
.tts-workspace .toast.visible { opacity: 1; }
.tts-workspace .toast.success { background: #ECFDF5; color: #065F46; border: 1px solid #A7F3D0; }
.tts-workspace .toast.error { background: #FEF2F2; color: #991B1B; border: 1px solid #FECACA; }
.tts-workspace .toast.info { background: #EEF2FF; color: #3730A3; border: 1px solid #C7D2FE; }

@media (max-width: 800px) {
  .tts-workspace .main { grid-template-columns: 1fr; }
  .tts-workspace .col-right { order: 99; }
  .tts-workspace .controls { gap: 12px; }
  .tts-workspace .voice-row select { min-width: 140px; }
  .tts-workspace .slider-row input[type="range"] { width: 80px; }
}
</style>

<div class="main">
  <!-- ========== 左栏 ========== -->
  <div class="col-left">

    <!-- 场景模板 -->
    <div class="card">
      <div class="card-title">📋 场景模板</div>
      <div class="template-chips" id="templateChips"></div>
    </div>

    <!-- 文字输入 -->
    <div class="card">
      <div class="card-title">📝 配音文本</div>
      <textarea class="text-input" id="textInput" placeholder="输入需要配音的文字，支持中文和英文&#10;提示：点击「智能分句」可将长文本拆成逐句配音">你好，欢迎使用语音工坊。这是一款专业的文字转语音工具，支持多种音色和语调调节。</textarea>
      <div class="char-row">
        <div class="char-info">
          <span>📊 <span id="charCount">0</span> 字</span>
          <span>⏱ 约 <strong id="estDuration">0</strong> 秒</span>
          <span>✂️ <span id="sentenceCount">0</span> 句</span>
        </div>
        <button class="btn-split" onclick="ttsSplitSentences()">✂️ 智能分句</button>
      </div>
    </div>

    <!-- 参数控制 -->
    <div class="card">
      <div class="controls">
        <div class="control-group">
          <label>🎙️ 音色</label>
          <div class="voice-row">
            <select id="voiceSelect"></select>
            <button class="btn-preview" onclick="ttsPreviewVoice()" title="试听">▶</button>
            <span class="voice-badge" id="ttsEngineBadge" style="font-size:10px;color:#9CA3AF;display:none">🌐 基础音质</span>
          </div>
        </div>
        <div class="control-group">
          <label>⏱ 语速</label>
          <div class="slider-row">
            <input type="range" id="speedRange" min="0.5" max="2.0" step="0.1" value="1.0" oninput="ttsUpdateSlider(this)">
            <span class="val" id="speedVal">1.0x</span>
          </div>
        </div>
        <div class="control-group">
          <label>🔊 音量</label>
          <div class="slider-row">
            <input type="range" id="volumeRange" min="0" max="10" step="1" value="8" oninput="ttsUpdateSlider(this)">
            <span class="val" id="volumeVal">8</span>
          </div>
        </div>
        <div class="control-group">
          <label>🎵 语调</label>
          <div class="slider-row">
            <input type="range" id="pitchRange" min="-20" max="20" step="1" value="0" oninput="this.nextElementSibling.textContent=(this.value>0?'+':'')+this.value+'Hz';ttsSavePitch(this.value)">
            <span class="val" id="pitchVal">0Hz</span>
          </div>
        </div>
      </div>
    </div>

    <!-- 生成按钮 -->
    <button class="btn-generate" id="generateBtn" onclick="ttsGenerate()">
      <span class="btn-text">🔊 生成语音</span>
      <span class="spinner"></span>
    </button>

    <!-- 播放器 -->
    <div class="card player" id="playerArea">
      <div class="card-title">🎧 当前音频</div>
      <div class="player-bar">
        <button class="btn-play" id="playBtn" onclick="ttsTogglePlay()">▶</button>
        <div class="progress-wrap" onclick="ttsSeek(event)">
          <div class="progress-fill" id="progressFill"></div>
        </div>
        <span class="player-time" id="playerTime">0:00 / 0:00</span>
      </div>
      <div class="player-actions">
        <button class="btn-action btn-download" onclick="ttsDownload()">⬇ 下载 MP3</button>
        <button class="btn-action btn-save-history" onclick="ttsSaveToHistory()">💾 保存到历史</button>
      </div>
    </div>

    <!-- 分句面板 -->
    <div class="card sentence-panel" id="sentencePanel">
      <div class="sentence-panel-header">
        <div class="card-title" style="margin-bottom:0">📑 逐句配音</div>
        <button class="btn-batch" onclick="ttsGenerateAll()" id="btnBatch">⚡ 生成全部</button>
      </div>
      <div id="sentenceList"></div>
    </div>

  </div>

  <!-- ========== 右栏：历史记录 ========== -->
  <div class="col-right">
    <div class="card">
      <div class="card-title" style="justify-content:space-between">
        📋 生成历史
        <span style="font-size:11px;font-weight:400;color:#9CA3AF" id="historyCount">0 条</span>
      </div>
      <div class="history-list" id="historyList">
        <div class="history-empty">还没有生成记录，开始配音吧 🎤</div>
      </div>
      <div class="history-clear"><button onclick="ttsClearHistory()">🗑️ 清空所有历史</button></div>
    </div>
  </div>
</div>

<!-- Toast -->
<div class="toast" id="ttsToast"></div>

<script>
// ==================== TTS 状态 ====================
var TTS = {
  voices: [],
  selectedVoice: 'tongtong',
  generatedBlob: null,
  currentAudio: null,
  isPlaying: false,
  currentAudioUrl: null,
  previewAudio: null,
  previewPlaying: false,
  sentences: [],
  history: [],
  batchCancelled: false,
};

var TTS_PREVIEW_TEXT = '你好，听听我的声音吧。';
var TTS_TEMPLATES = [
  { label: '短视频配音', text: '大家好，欢迎来到我的频道。今天我们要聊一个非常有趣的话题，如果你喜欢，记得点赞关注哦！' },
  { label: '广告促销',   text: '限时特惠，全场五折起！数量有限，先到先得。错过今天，再等一年！赶快行动起来吧！' },
  { label: '教程讲解',   text: '今天我们来学习一个非常实用的技巧。首先打开软件，然后点击左上角的菜单按钮，选择新建项目。' },
  { label: 'AI解说',    text: '你相信吗？眼前这个看似普通的装置，背后隐藏着一个惊人的科学原理。让我们一探究竟。' },
  { label: '通知公告',   text: '尊敬的各位同事，现发布重要通知。请大家注意查收并按时完成相关任务，感谢配合。' },
  { label: '有声读物',   text: '在很久很久以前，有一座被迷雾笼罩的森林。森林深处，住着一位神秘的老人，他守护着一个古老的秘密。' },
];

// ==================== 初始化 ====================
document.addEventListener('DOMContentLoaded', function() {
  ttsInit();
});

function ttsInit() {
  // 填充音色选择
  var sel = document.getElementById('voiceSelect');
  TTS.voices.forEach(function(v) {
    var opt = document.createElement('option');
    opt.value = v.id;
    opt.textContent = v.name;
    sel.appendChild(opt);
  });

  // 恢复上次音色
  var saved = localStorage.getItem('tts_voice');
  if (saved && TTS.voices.some(function(v) { return v.id === saved; })) {
    TTS.selectedVoice = saved;
    sel.value = saved;
  }
  sel.addEventListener('change', function(e) {
    TTS.selectedVoice = e.target.value;
    localStorage.setItem('tts_voice', e.target.value);
  });

  // 场景模板
  var tc = document.getElementById('templateChips');
  TTS_TEMPLATES.forEach(function(t) {
    var chip = document.createElement('span');
    chip.className = 'chip';
    chip.textContent = t.label;
    chip.onclick = function() {
      document.getElementById('textInput').value = t.text;
      ttsUpdateStats();
    };
    tc.appendChild(chip);
  });

  // 恢复音量/语速/语调
  var savedSpeed = localStorage.getItem('tts_speed');
  if (savedSpeed) { document.getElementById('speedRange').value = savedSpeed; ttsUpdateSlider(document.getElementById('speedRange')); }
  var savedVol = localStorage.getItem('tts_volume');
  if (savedVol) { document.getElementById('volumeRange').value = savedVol; ttsUpdateSlider(document.getElementById('volumeRange')); }
  var savedPitch = localStorage.getItem('tts_pitch');
  if (savedPitch != null) { document.getElementById('pitchRange').value = savedPitch; document.getElementById('pitchVal').textContent = (savedPitch>0?'+':'')+savedPitch+'Hz'; }

  // 恢复历史
  ttsLoadHistory();

  ttsUpdateStats();

  // 快捷键
  document.addEventListener('keydown', function(e) {
    if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') ttsGenerate();
  });
}

// 异步获取音色列表（可能从API或硬编码）
// 先从 localStorage 加载，同时异步拉取
(function() {
  // 硬编码保底音色（仅保留Edge TTS实际可用的标准音色）
  TTS.voices = [
    { id: 'tongtong', name: '晓晓 · 温柔女声' },
    { id: 'chuichui', name: '晓伊 · 活泼女声' },
    { id: 'xiaochen', name: '云希 · 青年男声' },
    { id: 'jam',      name: '云健 · 磁性男声' },
    { id: 'yunyang',  name: '云扬 · 阳光男声' },
    { id: 'yunxia',   name: '云夏 · 沉稳男声' },
  ];
})();

// ==================== 统计更新 ====================
function ttsUpdateStats() {
  var text = document.getElementById('textInput').value;
  document.getElementById('charCount').textContent = text.length;
  var segs = ttsSplitText(text);
  document.getElementById('sentenceCount').textContent = segs.length;
  var speed = parseFloat(document.getElementById('speedRange').value);
  var estSec = Math.ceil(text.length / (3.5 * speed));
  document.getElementById('estDuration').textContent = estSec;
}

function ttsUpdateSlider(el) {
  var id = el.id, v = parseFloat(el.value);
  if (id === 'speedRange') {
    document.getElementById('speedVal').textContent = v.toFixed(1) + 'x';
    localStorage.setItem('tts_speed', v);
  } else if (id === 'volumeRange') {
    document.getElementById('volumeVal').textContent = v;
    localStorage.setItem('tts_volume', v);
  }
  ttsUpdateStats();
}

function ttsSavePitch(v) {
  localStorage.setItem('tts_pitch', v);
}

// ==================== Toast ====================
function ttsToast(msg, type) {
  var t = document.getElementById('ttsToast');
  t.textContent = msg;
  t.className = 'toast visible ' + (type || 'success');
  clearTimeout(t._timer);
  t._timer = setTimeout(function() { t.classList.remove('visible'); }, 2800);
}

// ==================== 文本分句 ====================
function ttsSplitText(text) {
  return text.split(/(?<=[。！？；\.!\?;\n])/g).map(function(s) { return s.trim(); }).filter(function(s) { return s.length > 0; });
}

function ttsSplitSentences() {
  var text = document.getElementById('textInput').value.trim();
  if (!text) { ttsToast('请先输入配音文本', 'error'); return; }
  var segs = ttsSplitText(text);
  TTS.sentences = segs.map(function(txt, i) {
    return { id: Date.now() + '_' + i, text: txt, blob: null, status: 'pending', duration: 0 };
  });
  ttsRenderSentences();
  document.getElementById('sentencePanel').classList.add('visible');
  ttsToast('已拆分为 ' + segs.length + ' 句', 'info');
}

function ttsRenderSentences() {
  var container = document.getElementById('sentenceList');
  container.innerHTML = TTS.sentences.map(function(s, i) {
    return '<div class="sentence-item status-' + s.status + '" id="sent-' + s.id + '">' +
      '<span class="idx">' + (s.status === 'generating' ? '⏳' : s.status === 'done' ? '✅' : String(i + 1)) + '</span>' +
      '<span class="txt">' + ttsEscape(s.text) + '</span>' +
      '<span class="s-actions">' +
        (s.status === 'done'
          ? '<button class="s-btn play-btn" onclick="ttsPlaySentence(\'' + s.id + '\')">▶</button>' +
            '<button class="s-btn" onclick="ttsDownloadSentence(\'' + s.id + '\')">⬇</button>'
          : s.status === 'generating'
          ? '<span style="font-size:11px;color:#9CA3AF">生成中…</span>'
          : '<button class="s-btn" onclick="ttsGenSentence(\'' + s.id + '\')">🎤</button>') +
      '</span></div>';
  }).join('');
}

function ttsFindSentence(id) {
  for (var i = 0; i < TTS.sentences.length; i++) {
    if (TTS.sentences[i].id === id) return TTS.sentences[i];
  }
  return null;
}

async function ttsGenSentence(id) {
  var s = ttsFindSentence(id);
  if (!s || s.status === 'generating') return;
  s.status = 'generating';
  ttsRenderSentences();
  try {
    var blob = await ttsDoTTS(s.text, TTS.selectedVoice);
    s.blob = blob;
    s.status = 'done';
    ttsSaveSentenceToHistory(s);
  } catch (e) {
    s.status = 'pending';
    ttsToast('生成失败: ' + e.message, 'error');
  }
  ttsRenderSentences();
}

async function ttsGenerateAll() {
  var btn = document.getElementById('btnBatch');
  btn.disabled = true;
  TTS.batchCancelled = false;
  var pending = [];
  for (var i = 0; i < TTS.sentences.length; i++) {
    if (TTS.sentences[i].status === 'pending') pending.push(TTS.sentences[i]);
  }
  if (pending.length === 0) { ttsToast('所有句子已生成', 'info'); btn.disabled = false; return; }
  ttsToast('开始生成 ' + pending.length + ' 句…', 'info');
  for (var j = 0; j < pending.length; j++) {
    if (TTS.batchCancelled) break;
    btn.textContent = '生成中 ' + (j + 1) + '/' + pending.length;
    await ttsGenSentence(pending[j].id);
  }
  if (!TTS.batchCancelled) ttsToast('全部生成完成 ✅', 'success');
  TTS.batchCancelled = false;
  btn.textContent = '⚡ 生成全部';
  btn.disabled = false;
}

function ttsPlaySentence(id) {
  var s = ttsFindSentence(id);
  if (!s || !s.blob) return;
  ttsPlayBlob(s.blob);
}

function ttsDownloadSentence(id) {
  var s = ttsFindSentence(id);
  if (!s || !s.blob) return;
  ttsDownloadBlob(s.blob, 'sentence_' + id + '.mp3');
}

function ttsSaveSentenceToHistory(s) {
  if (!s.blob) return;
  TTS.history.unshift({
    id: 'hist_' + Date.now(),
    text: s.text,
    voice: TTS.selectedVoice,
    voiceName: (function() { for (var i = 0; i < TTS.voices.length; i++) { if (TTS.voices[i].id === TTS.selectedVoice) return TTS.voices[i].name; } return ''; })(),
    blob: s.blob,
    duration: s.duration || 0,
    time: new Date().toLocaleString('zh-CN'),
  });
  ttsRenderHistory();
  ttsPersistHistory();
}

// ==================== 音色试听 ====================
async function ttsPreviewVoice() {
  if (TTS.previewPlaying) {
    if (TTS.previewAudio) { TTS.previewAudio.pause(); TTS.previewAudio = null; }
    TTS.previewPlaying = false;
    document.querySelector('.btn-preview').classList.remove('playing');
    document.querySelector('.btn-preview').textContent = '▶';
    return;
  }
  var btn = document.querySelector('.btn-preview');
  btn.classList.add('playing');
  btn.textContent = '⏳';
  try {
    var blob = await ttsDoTTS(TTS_PREVIEW_TEXT, TTS.selectedVoice);
    var url = URL.createObjectURL(blob);
    TTS.previewAudio = new Audio(url);
    TTS.previewAudio.onended = function() {
      TTS.previewPlaying = false;
      btn.classList.remove('playing');
      btn.textContent = '▶';
      URL.revokeObjectURL(url);
      TTS.previewAudio = null;
    };
    TTS.previewAudio.onerror = function() {
      TTS.previewPlaying = false;
      btn.classList.remove('playing');
      btn.textContent = '▶';
      TTS.previewAudio = null;
      ttsToast('试听失败', 'error');
    };
    await TTS.previewAudio.play();
    TTS.previewPlaying = true;
    btn.classList.add('playing');
    btn.textContent = '⏹';
  } catch (e) {
    TTS.previewPlaying = false;
    btn.classList.remove('playing');
    btn.textContent = '▶';
    ttsToast('试听失败', 'error');
  }
}

// ==================== 核心生成 ====================
async function ttsDoTTS(text, voice) {
  var speed = parseFloat(document.getElementById('speedRange').value);
  var volume = parseFloat(document.getElementById('volumeRange').value);
  var pitch = parseInt(document.getElementById('pitchRange').value);

  var res = await fetch('/api/free-tts', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ text: text, voice: voice, speed: speed, volume: volume, pitch: pitch }),
  });
  if (!res.ok) throw new Error('合成失败');
  var blob = await res.blob();

  // 检测TTS引擎
  var engine = res.headers.get('X-TTS-Engine') || 'edge';
  var badge = document.getElementById('ttsEngineBadge');
  if (badge) {
    if (engine === 'google') {
      badge.style.display = 'inline';
    } else {
      badge.style.display = 'none';
    }
  }

  // 裁剪开头静音
  try { blob = await ttsTrimSilence(blob); } catch(e) { console.warn('静音裁剪失败:', e); }

  // 验证
  try {
    var ctx = new (window.AudioContext || window.webkitAudioContext)();
    await ctx.decodeAudioData(await blob.arrayBuffer());
    ctx.close();
  } catch(e) { throw new Error('音频解码失败'); }

  return blob;
}

async function ttsGenerate() {
  var text = document.getElementById('textInput').value.trim();
  if (!text) { ttsToast('请输入配音文本', 'error'); return; }

  var btn = document.getElementById('generateBtn');
  btn.disabled = true;
  btn.className = 'btn-generate progress';
  document.getElementById('playerArea').classList.remove('visible');

  try {
    var blob = await ttsDoTTS(text, TTS.selectedVoice);
    TTS.generatedBlob = blob;
    ttsShowPlayer(blob);
    ttsToast('生成成功 ✅', 'success');
  } catch (e) {
    ttsToast(e.message || '生成失败', 'error');
  } finally {
    btn.disabled = false;
    btn.className = 'btn-generate';
  }
}

// ==================== 播放器 ====================
function ttsShowPlayer(blob) {
  ttsStopAudio();
  var url = URL.createObjectURL(blob);
  TTS.currentAudioUrl = url;
  TTS.currentAudio = new Audio(url);
  var a = TTS.currentAudio;
  a.addEventListener('timeupdate', ttsUpdateProgress);
  a.addEventListener('loadedmetadata', function() {
    document.getElementById('playerTime').textContent = '0:00 / ' + ttsFormatTime(Math.floor(a.duration));
  });
  a.addEventListener('ended', function() {
    TTS.isPlaying = false;
    document.getElementById('playBtn').textContent = '▶';
  });
  a.addEventListener('error', function() {
    TTS.isPlaying = false;
    document.getElementById('playBtn').textContent = '▶';
    ttsToast('音频无法播放', 'error');
  });
  document.getElementById('playerArea').classList.add('visible');
  document.getElementById('playBtn').textContent = '▶';
  document.getElementById('progressFill').style.width = '0%';
}

function ttsPlayBlob(blob) {
  ttsShowPlayer(blob);
  setTimeout(function() { ttsTogglePlay(); }, 150);
}

function ttsStopAudio() {
  if (TTS.previewAudio) { TTS.previewAudio.pause(); TTS.previewAudio = null; TTS.previewPlaying = false; var pb = document.querySelector('.btn-preview'); if(pb) { pb.classList.remove('playing'); pb.textContent = '▶'; } }
  if (TTS.currentAudio) { TTS.currentAudio.pause(); }
  if (TTS.currentAudioUrl) { URL.revokeObjectURL(TTS.currentAudioUrl); TTS.currentAudioUrl = null; }
  TTS.currentAudio = null;
  TTS.isPlaying = false;
}

function ttsTogglePlay() {
  if (!TTS.currentAudio) return;
  var btn = document.getElementById('playBtn');
  if (TTS.isPlaying) {
    TTS.currentAudio.pause();
    TTS.isPlaying = false;
    btn.textContent = '▶';
  } else {
    TTS.currentAudio.play();
    TTS.isPlaying = true;
    btn.textContent = '⏸';
  }
}

function ttsUpdateProgress() {
  if (!TTS.currentAudio) return;
  var d = TTS.currentAudio.duration;
  if (!d) return;
  document.getElementById('progressFill').style.width = ((TTS.currentAudio.currentTime / d) * 100) + '%';
  document.getElementById('playerTime').textContent =
    ttsFormatTime(Math.floor(TTS.currentAudio.currentTime)) + ' / ' + ttsFormatTime(Math.floor(d));
}

function ttsSeek(e) {
  if (!TTS.currentAudio) return;
  var rect = e.currentTarget.getBoundingClientRect();
  TTS.currentAudio.currentTime = ((e.clientX - rect.left) / rect.width) * TTS.currentAudio.duration;
}

function ttsDownload() {
  if (!TTS.generatedBlob) return;
  ttsDownloadBlob(TTS.generatedBlob, 'speech.mp3');
}

function ttsDownloadBlob(blob, name) {
  var a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = name;
  a.click();
  setTimeout(function() { URL.revokeObjectURL(a.href); }, 5000);
}

// ==================== 静音裁剪 ====================
async function ttsTrimSilence(blob, threshold) {
  if (threshold === undefined) threshold = 0.01;
  var ctx = new (window.AudioContext || window.webkitAudioContext)();
  var buf = await ctx.decodeAudioData(await blob.arrayBuffer());
  var channel = buf.getChannelData(0);
  var start = 0;
  for (var i = 0; i < channel.length; i++) {
    if (Math.abs(channel[i]) > threshold) {
      start = Math.max(0, i - Math.floor(ctx.sampleRate * 0.02));
      break;
    }
  }
  if (start <= 0) { ctx.close(); return blob; }
  var trimmedLen = buf.length - start;
  var offCtx = new OfflineAudioContext(buf.numberOfChannels, trimmedLen, ctx.sampleRate);
  var newBuf = ctx.createBuffer(buf.numberOfChannels, trimmedLen, ctx.sampleRate);
  for (var ch = 0; ch < buf.numberOfChannels; ch++) {
    var srcData = buf.getChannelData(ch);
    var dstData = newBuf.getChannelData(ch);
    for (var j = 0; j < trimmedLen; j++) dstData[j] = srcData[j + start];
  }
  var src = offCtx.createBufferSource();
  src.buffer = newBuf;
  src.connect(offCtx.destination);
  src.start();
  var rendered = await offCtx.startRendering();
  ctx.close();
  var nc = rendered.numberOfChannels, sr = rendered.sampleRate, len = rendered.length;
  var wav = new ArrayBuffer(44 + len * nc * 2);
  var v = new DataView(wav);
  function ws(o, s) { for (var i = 0; i < s.length; i++) v.setUint8(o + i, s.charCodeAt(i)); }
  ws(0, 'RIFF'); v.setUint32(4, 36 + len * nc * 2, true);
  ws(8, 'WAVE'); ws(12, 'fmt ');
  v.setUint32(16, 16, true); v.setUint16(20, 1, true);
  v.setUint16(22, nc, true); v.setUint32(24, sr, true);
  v.setUint32(28, sr * nc * 2, true);
  v.setUint16(32, nc * 2, true); v.setUint16(34, 16, true);
  ws(36, 'data'); v.setUint32(40, len * nc * 2, true);
  var off = 44;
  for (var i2 = 0; i2 < len; i2++) {
    for (var ch2 = 0; ch2 < nc; ch2++) {
      var s = Math.max(-1, Math.min(1, rendered.getChannelData(ch2)[i2]));
      v.setInt16(off, s < 0 ? s * 0x8000 : s * 0x7FFF, true);
      off += 2;
    }
  }
  return new Blob([wav], { type: 'audio/wav' });
}

// ==================== 历史记录 ====================
function ttsSaveToHistory() {
  if (!TTS.generatedBlob) { ttsToast('请先生成语音', 'error'); return; }
  var text = document.getElementById('textInput').value.trim();
  var vName = '';
  for (var i = 0; i < TTS.voices.length; i++) { if (TTS.voices[i].id === TTS.selectedVoice) { vName = TTS.voices[i].name; break; } }
  TTS.history.unshift({
    id: 'hist_' + Date.now(),
    text: text.slice(0, 80),
    voice: TTS.selectedVoice,
    voiceName: vName,
    blob: TTS.generatedBlob,
    duration: TTS.currentAudio ? Math.floor(TTS.currentAudio.duration || 0) : 0,
    time: new Date().toLocaleString('zh-CN'),
  });
  ttsRenderHistory();
  ttsPersistHistory();
  ttsToast('已保存到历史 ✅', 'success');
}

function ttsRenderHistory() {
  var container = document.getElementById('historyList');
  document.getElementById('historyCount').textContent = TTS.history.length + ' 条';
  if (TTS.history.length === 0) {
    container.innerHTML = '<div class="history-empty">还没有生成记录，开始配音吧 🎤</div>';
    return;
  }
  container.innerHTML = TTS.history.map(function(h) {
    return '<div class="history-item" title="' + ttsEscape(h.text) + '">' +
      '<div class="h-info">' +
        '<div class="h-text">' + ttsEscape(h.text) + '</div>' +
        '<div class="h-meta">' + h.voiceName + ' · ' + ttsFormatTime(h.duration) + ' · ' + h.time + '</div>' +
      '</div>' +
      '<div class="h-actions">' +
        '<button class="h-btn" onclick="event.stopPropagation();ttsPlayHistory(\'' + h.id + '\')" title="播放">▶</button>' +
        '<button class="h-btn" onclick="event.stopPropagation();ttsDownloadHistory(\'' + h.id + '\')" title="下载">⬇</button>' +
        '<button class="h-btn danger" onclick="event.stopPropagation();ttsDeleteHistory(\'' + h.id + '\')" title="删除">✕</button>' +
      '</div></div>';
  }).join('');
}

function ttsFindHistory(id) {
  for (var i = 0; i < TTS.history.length; i++) { if (TTS.history[i].id === id) return TTS.history[i]; }
  return null;
}

function ttsPlayHistory(id) {
  var h = ttsFindHistory(id);
  if (!h || !h.blob) return;
  ttsPlayBlob(h.blob);
}

function ttsDownloadHistory(id) {
  var h = ttsFindHistory(id);
  if (!h || !h.blob) return;
  ttsDownloadBlob(h.blob, 'dub_' + h.id + '.mp3');
}

function ttsDeleteHistory(id) {
  var idx = -1;
  for (var i = 0; i < TTS.history.length; i++) { if (TTS.history[i].id === id) { idx = i; break; } }
  if (idx === -1) return;
  TTS.history.splice(idx, 1);
  ttsRenderHistory();
  ttsPersistHistory();
}

function ttsClearHistory() {
  if (!confirm('确定清空所有历史记录？')) return;
  TTS.history = [];
  ttsRenderHistory();
  ttsPersistHistory();
  ttsToast('历史已清空', 'info');
}

function ttsPersistHistory() {
  var meta = TTS.history.map(function(h) {
    return { id: h.id, text: h.text, voice: h.voice, voiceName: h.voiceName, duration: h.duration, time: h.time, hasBlob: !!h.blob };
  });
  try { localStorage.setItem('tts_history', JSON.stringify(meta)); } catch(e) {}
}

function ttsLoadHistory() {
  try {
    var raw = localStorage.getItem('tts_history');
    if (!raw) return;
    TTS.history = JSON.parse(raw).map(function(h) { return { ...h, blob: null }; });
    ttsRenderHistory();
  } catch(e) { console.warn('读取历史失败:', e); }
}

// ==================== 工具函数 ====================
function ttsFormatTime(s) {
  if (!s || isNaN(s)) return '0:00';
  return Math.floor(s / 60) + ':' + (s % 60 < 10 ? '0' : '') + Math.floor(s % 60);
}

function ttsEscape(str) {
  var d = document.createElement('div');
  d.textContent = str;
  return d.innerHTML;
}
</script>
</div>