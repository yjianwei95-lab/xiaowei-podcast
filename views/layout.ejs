<!DOCTYPE html>
<html lang="zh-CN" data-theme="auto">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="theme-color" content="#4A90D9">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="小伟播客">
  <link rel="apple-touch-icon" href="/icon-192.png">
  <link rel="apple-touch-startup-image" href="/icon-512.png">
  <link rel="manifest" href="/manifest.json">
  <title><%= typeof title !== 'undefined' ? (title ? title + ' - ' : '') : '' %>小伟播客</title>
  <meta name="description" content="<%= typeof pageDescription !== 'undefined' ? pageDescription : '小伟播客 - 上传你的声音，分享你的故事。支持语音配音、音频编辑、在线播放，打造你的个人播客平台。' %>">
  <meta name="keywords" content="播客,Podcast,小伟播客,语音配音,TTS,音频编辑,在线播客,声音分享,有声内容,语音合成">
  <meta name="author" content="小伟播客">
  <meta name="robots" content="index,follow">
  <link rel="canonical" href="https://xiaowei-podcast-production.up.railway.app<%= typeof canonicalPath !== 'undefined' ? canonicalPath : '' %>">
  <!-- Baidu Site Verification - 请替换为你的验证码 -->
  <meta name="baidu-site-verification" content="codeva-UNmSd6Bx3e">
  <!-- Open Graph -->
  <meta property="og:title" content="<%= typeof title !== 'undefined' ? (title ? title + ' - ' : '') : '' %>小伟播客">
  <meta property="og:description" content="<%= typeof pageDescription !== 'undefined' ? pageDescription : '上传你的声音，分享你的故事。语音配音、音频编辑、在线播放。' %>">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://xiaowei-podcast-production.up.railway.app<%= typeof canonicalPath !== 'undefined' ? canonicalPath : '' %>">
  <meta property="og:site_name" content="小伟播客">
  <meta property="og:locale" content="zh_CN">
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="<%= typeof title !== 'undefined' ? (title ? title + ' - ' : '') : '' %>小伟播客">
  <meta name="twitter:description" content="<%= typeof pageDescription !== 'undefined' ? pageDescription : '上传你的声音，分享你的故事。' %>">
  <link rel="stylesheet" href="/css/style.css?v=5">
  <style>
  /* 欢迎横幅全局样式 */
  .site-banner-wrap {
    position: relative;
    width: 100%;
    overflow: hidden;
    height: 44px;
    background: linear-gradient(90deg, #EEF2FF, #E0E7FF, #C7D2FE);
    border-radius: 10px;
    margin-bottom: 16px;
    transition: opacity 0.5s ease, height 0.5s ease, margin 0.5s ease;
  }
  .site-banner-wrap.hidden {
    opacity: 0;
    height: 0;
    margin-bottom: 0;
    pointer-events: none;
  }
  .site-banner-inner {
    position: absolute;
    top: 0;
    left: 0;
    height: 44px;
    line-height: 44px;
    white-space: nowrap;
    font-size: 14px;
    font-weight: 500;
    color: #3730A3;
    padding: 0 4px;
  }
  .site-banner-inner::before { content: "✨ "; }
  </style>
</head>
<body>
  <!-- APP 环境检测：WebView 自定义 UserAgent 标记 -->
  <script>
  if (/XiaoWeiPodcast/i.test(navigator.userAgent)) {
    document.body.classList.add('is-app');
  }
  </script>
  <!-- 当前 sessionId（Cookie 被吞时前端靠它恢复登录态） -->
  <script>window.__SID__ = '<%= (typeof sid !== "undefined" && sid) ? sid : "" %>';</script>
  <nav class="navbar">
    <div class="container">
      <a href="/" class="logo">🎙️ 小伟播客</a>
      <div class="nav-links">
        <a href="/">首页</a>
        <a href="/tts" style="color:#6366F1;font-weight:bold">🎤 语音配音</a>
        <a href="/recorder">🎙️ 录音室</a>
        <a href="/upload">上传声音</a>
        <a href="/audio-editor" style="color:#FFD700;font-weight:bold">🎵 音频编辑</a>
        <% if (typeof session !== 'undefined' && session && (session.loggedIn || session.isAdmin || session.userId)) { %>
          <span class="nav-user">👤 <%= session.nickname || session.phone || session.username || '用户' %></span>
          <a href="/my">📁 我的作品</a>
          <a href="/profile">✏️ 编辑资料</a>
          <% if (session.isAdmin || session.loggedIn) { %>
          <a href="/ops" style="color:#FFD700">🔧 运营</a>
          <% } %>
          <a href="/logout" class="nav-logout">退出</a>
        <% } else { %>
          <a href="/phone-login">登录</a>
          <a href="/register">注册</a>
        <% } %>
        <!-- 主题切换 -->
        <div class="theme-switcher" id="themeSwitcher">
          <button class="theme-toggle" id="themeBtn" aria-label="切换主题">
            <span id="themeIcon">🌙</span>
          </button>
          <div class="theme-menu" id="themeMenu">
            <button class="theme-option" data-theme="light">
              <span class="theme-opt-icon">☀️</span>
              <span>亮色</span>
              <span class="theme-check" id="checkLight"></span>
            </button>
            <button class="theme-option" data-theme="dark">
              <span class="theme-opt-icon">🌙</span>
              <span>暗色</span>
              <span class="theme-check" id="checkDark"></span>
            </button>
            <button class="theme-option" data-theme="auto">
              <span class="theme-opt-icon">🖥️</span>
              <span>自动</span>
              <span class="theme-check" id="checkAuto"></span>
            </button>
          </div>
        </div>
      </div>
    </div>
  </nav>
  <main class="container">
    <% if (typeof flash !== 'undefined' && flash) { %>
      <div class="flash <%= flash.category %>"><%= flash.message %></div>
    <% } %>
    <div class="site-banner-wrap" id="siteBanner">
      <div class="site-banner-inner" id="siteBannerInner">语音配音工作台全新上线 🎉 支持12种音色 · 语调/语速/音量自由调节 · 智能分句批量生成 · 场景模板一键切换 · 生成历史自动保存</div>
    </div>
    <%- content %>
  </main>
  <footer class="footer">
    <div class="container">
      <p>🎙️ 小伟播客 · 用声音连接你我</p>
      <p style="margin-top:5px;font-size:12px;opacity:0.7">
      </p>
    </div>
  </footer>

  <!-- 主题切换 JS -->
  <script>
  (function() {
    const THEME_KEY = 'xiaowei-theme';
    const root = document.documentElement;
    const btn = document.getElementById('themeBtn');
    const menu = document.getElementById('themeMenu');
    const icon = document.getElementById('themeIcon');

    function getSystemTheme() {
      return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    }

    function applyTheme(theme) {
      if (theme === 'auto') {
        root.removeAttribute('data-theme');
      } else {
        root.setAttribute('data-theme', theme);
      }
      updateIcon(theme);
      updateChecks(theme);
    }

    function updateIcon(theme) {
      if (theme === 'auto') {
        icon.textContent = '🖥️';
      } else if (theme === 'light') {
        icon.textContent = '☀️';
      } else {
        icon.textContent = '🌙';
      }
    }

    function updateChecks(theme) {
      const checks = { light: 'checkLight', dark: 'checkDark', auto: 'checkAuto' };
      Object.keys(checks).forEach(key => {
        const el = document.getElementById(checks[key]);
        if (el) el.textContent = key === theme ? '✓' : '';
      });
    }

    function initTheme() {
      const saved = localStorage.getItem(THEME_KEY) || 'auto';
      applyTheme(saved);

      // 监听系统主题变化（自动模式下）
      window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function(e) {
        if ((localStorage.getItem(THEME_KEY) || 'auto') === 'auto') {
          // auto模式下系统主题变了，重新计算但不需要改data-theme（无属性=auto）
        }
      });
    }

    // 按钮点击：切换菜单显示
    btn.addEventListener('click', function(e) {
      e.stopPropagation();
      menu.classList.toggle('show');
    });

    // 菜单选项点击
    document.querySelectorAll('.theme-option').forEach(function(opt) {
      opt.addEventListener('click', function() {
        const theme = this.getAttribute('data-theme');
        localStorage.setItem(THEME_KEY, theme);
        applyTheme(theme);
        menu.classList.remove('show');
      });
    });

    // 点击空白关闭菜单
    document.addEventListener('click', function() {
      menu.classList.remove('show');
    });

    initTheme();
  })();
  </script>

  <!-- ─── 移动端底部导航 ─── -->
  <nav class="mobile-nav" id="mobileNav">
    <a href="/tts" class="mobile-nav-item" data-path="/tts">
      <span class="mobile-nav-icon">🎤</span>
      <span class="mobile-nav-label">配音</span>
    </a>
    <a href="/" class="mobile-nav-item" data-path="/">
      <span class="mobile-nav-icon">🏠</span>
      <span class="mobile-nav-label">首页</span>
    </a>
    <a href="/audio-editor" class="mobile-nav-item" data-path="/audio-editor">
      <span class="mobile-nav-icon">🎵</span>
      <span class="mobile-nav-label">音频</span>
    </a>
    <a href="/upload" class="mobile-nav-item" data-path="/upload">
      <span class="mobile-nav-icon">📤</span>
      <span class="mobile-nav-label">上传</span>
    </a>
    <button class="mobile-nav-item" id="mobileProfileBtn" data-path="/profile">
      <span class="mobile-nav-icon">👤</span>
      <span class="mobile-nav-label">我的</span>
    </button>
  </nav>

  <!-- 个人中心面板 -->
  <div class="profile-overlay" id="profileOverlay"></div>
  <div class="profile-sheet" id="profileSheet">
    <div class="profile-sheet-handle"></div>
    <div class="profile-sheet-content">
      <div class="profile-user-card">
        <div class="profile-avatar">👤</div>
        <div class="profile-info">
          <div class="profile-name" id="profileName"><%= (typeof session !== 'undefined' && session && (session.nickname || session.phone || session.username)) || '未登录' %></div>
          <div class="profile-detail" id="profileDetail"><%= (typeof session !== 'undefined' && session && session.phone) || '' %></div>
        </div>
      </div>
      <div class="profile-section">
        <div class="profile-section-title">主题设置</div>
        <div class="profile-theme-row">
          <button class="profile-theme-btn" data-theme="light"><span>☀️</span><span>亮色</span></button>
          <button class="profile-theme-btn" data-theme="dark"><span>🌙</span><span>暗色</span></button>
          <button class="profile-theme-btn" data-theme="auto"><span>🖥️</span><span>自动</span></button>
        </div>
      </div>
      <div class="profile-section">
        <% if (typeof session !== 'undefined' && session && (session.loggedIn || session.isAdmin || session.userId)) { %>
        <a href="/my" class="profile-logout-btn">📁 我的作品</a>
        <a href="/profile" class="profile-logout-btn" style="background:linear-gradient(135deg,var(--accent),var(--accent2));color:#fff;">✏️ 编辑资料</a>
        <a href="/logout" class="profile-logout-btn">退出登录</a>
        <% } else { %>
        <a href="/phone-login" class="profile-logout-btn" style="background:linear-gradient(135deg,var(--accent),var(--accent2));color:#fff;">邮箱登录</a>
        <% } %>
      </div>
    </div>
  </div>

  <!-- 移动端导航 JS -->
  <script>
  (function() {
    var profileOverlay = document.getElementById('profileOverlay');
    var profileSheet = document.getElementById('profileSheet');
    var profileBtn = document.getElementById('mobileProfileBtn');

    // 底部导航高亮当前页
    var currentPath = window.location.pathname;
    document.querySelectorAll('.mobile-nav-item[data-path]').forEach(function(item) {
      var path = item.getAttribute('data-path');
      if (path === '/profile') return; // "我的"是面板，不高亮
      if (currentPath === path || (path === '/' && currentPath === '/')) {
        item.classList.add('active');
      }
      // 子路径也高亮（如 /audio-editor 下的子页面）
      if (path !== '/' && currentPath.indexOf(path) === 0) {
        item.classList.add('active');
      }
    });

    // 打开个人面板
    profileBtn.addEventListener('click', function() {
      var isOpen = profileSheet.classList.contains('show');
      if (isOpen) {
        closeProfile();
      } else {
        openProfile();
      }
    });

    // 点击遮罩关闭
    profileOverlay.addEventListener('click', closeProfile);

    function openProfile() {
      profileOverlay.classList.add('show');
      profileSheet.classList.add('show');
      document.body.style.overflow = 'hidden';
      profileBtn.classList.add('active');
    }

    function closeProfile() {
      profileOverlay.classList.remove('show');
      profileSheet.classList.remove('show');
      document.body.style.overflow = '';
      profileBtn.classList.remove('active');
    }

    // 面板内主题切换
    document.querySelectorAll('.profile-theme-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var theme = this.getAttribute('data-theme');
        localStorage.setItem('xiaowei-theme', theme);
        if (theme === 'auto') {
          document.documentElement.removeAttribute('data-theme');
        } else {
          document.documentElement.setAttribute('data-theme', theme);
        }
        // 更新图标
        var iconEl = document.getElementById('themeIcon');
        if (iconEl) {
          iconEl.textContent = theme === 'light' ? '☀️' : theme === 'dark' ? '🌙' : '🖥️';
        }
        // 更新选中状态
        updateProfileThemeActive(theme);
      });
    });

    function updateProfileThemeActive(theme) {
      document.querySelectorAll('.profile-theme-btn').forEach(function(btn) {
        btn.classList.toggle('active', btn.getAttribute('data-theme') === theme);
      });
    }

    // 初始化主题按钮选中状态
    var savedTheme = localStorage.getItem('xiaowei-theme') || 'auto';
    updateProfileThemeActive(savedTheme);
  })();
  </script>

  <!-- 欢迎横幅动画 -->
  <script>
  (function() {
    var banner = document.getElementById('siteBanner');
    var inner = document.getElementById('siteBannerInner');
    if (!banner || !inner) return;

    var containerW = banner.offsetWidth;
    var textW = inner.scrollWidth;
    var gap = 40;
    var distance = containerW + textW + gap * 2;

    inner.style.transform = 'translateX(' + (containerW + gap) + 'px)';

    var passes = 0;
    var startTime = null;
    var durationPerPass = Math.max(6000, distance * 5);

    function frame(timestamp) {
      if (!startTime) startTime = timestamp;
      var elapsed = timestamp - startTime;
      var progress = elapsed / durationPerPass;

      if (progress >= 1) {
        passes++;
        if (passes >= 2) {
          banner.classList.add('hidden');
          return;
        }
        startTime = timestamp;
        inner.style.transform = 'translateX(' + (containerW + gap) + 'px)';
        requestAnimationFrame(frame);
        return;
      }

      var x = (containerW + gap) - (distance * progress);
      inner.style.transform = 'translateX(' + x + 'px)';
      requestAnimationFrame(frame);
    }

    requestAnimationFrame(frame);
  })();
  </script>

  <!-- session 兜底：Cookie 不可用时用 sid 维持登录态（Cloud Studio 预览/iframe） -->
  <script>
  (function(){
    var SID = new URLSearchParams(location.search).get('sid') || window.__SID__ || localStorage.getItem('xw_sid') || '';
    if (!SID) return;
    localStorage.setItem('xw_sid', SID);
    // 把 sid 写回当前 URL，保证手动刷新也能保持登录
    if (!new URLSearchParams(location.search).get('sid')) {
      history.replaceState(null, '', location.pathname + '?sid=' + encodeURIComponent(SID));
    }
    // 拦截同域链接点击，追加 sid
    document.addEventListener('click', function(e){
      var a = e.target.closest && e.target.closest('a');
      if (!a) return;
      var href = a.getAttribute('href') || '';
      if (!href || href.charAt(0) === '#' || a.target === '_blank' || href.indexOf('sid=') !== -1) return;
      if (href.indexOf('://') !== -1 && href.indexOf(location.origin) !== 0) return;
      try {
        var u = new URL(href, location.origin);
        if (u.origin !== location.origin) return;
        u.searchParams.set('sid', SID);
        a.setAttribute('href', u.pathname + u.search + u.hash);
      } catch(_){}
    }, true);
    // 表单提交追加隐藏 sid
    document.addEventListener('submit', function(e){
      var f = e.target;
      if (!f || f.tagName !== 'FORM') return;
      if (f.method && f.method.toUpperCase() === 'GET') return;
      if (f.querySelector('input[name="sid"]')) return;
      var inp = document.createElement('input');
      inp.type = 'hidden'; inp.name = 'sid'; inp.value = SID;
      f.appendChild(inp);
    }, true);
    // fetch / XHR 带 sid
    var origFetch = window.fetch;
    if (origFetch) {
      window.fetch = function(url, opts){
        opts = opts || {};
        opts.headers = opts.headers || {};
        if (!(opts.headers instanceof Headers)) opts.headers = new Headers(opts.headers);
        opts.headers.set('x-sid', SID);
        return origFetch.call(window, url, opts);
      };
    }
    var origOpen = XMLHttpRequest.prototype.open;
    if (origOpen) {
      XMLHttpRequest.prototype.open = function(method, url){
        var r = origOpen.apply(this, arguments);
        try { this.setRequestHeader('x-sid', SID); } catch(_){}
        return r;
      };
    }
  })();
  </script>
</body>
</html>
