<div class="admin-bar">
  <h1>✏️ 编辑播客</h1>
  <a href="/admin/podcasts" class="btn btn-secondary">← 返回</a>
</div>

<form method="POST" class="admin-form">
  <div class="form-group">
    <label>标题</label>
    <input type="text" name="title" value="<%= podcast.title %>" required class="form-input">
  </div>
  <div class="form-group">
    <label>上传者</label>
    <input type="text" name="uploader_name" value="<%= podcast.uploader_name %>" class="form-input">
  </div>
  <div class="form-group">
    <label>邮箱</label>
    <input type="email" name="uploader_email" value="<%= podcast.uploader_email %>" class="form-input">
  </div>
  <div class="form-group">
    <label>描述</label>
    <textarea name="description" rows="4" class="form-input"><%= podcast.description || '' %></textarea>
  </div>
  <div class="form-actions">
    <button type="submit" class="btn btn-primary">保存修改</button>
    <a href="/admin/podcasts" class="btn btn-secondary">取消</a>
  </div>
</form>

<% if (podcast.filename) { %>
<div style="margin-top:30px;padding-top:20px;border-top:1px solid #eee">
  <h3 style="margin-bottom:12px">🎵 当前音频</h3>
  <audio src="/uploads/<%= podcast.filename %>?v=<%= podcast.created_at ? Date.parse(podcast.created_at) : '' %>" controls style="width:100%;max-width:400px"></audio>
  <p style="font-size:12px;color:#999;margin-top:6px"><%= podcast.original_name %> (<%= (podcast.file_size / 1048576).toFixed(1) %> MB)</p>
  
  <h3 style="margin:20px 0 12px">📤 替换音频</h3>
  <form action="/admin/replace-audio/<%= podcast.id %>" method="POST" enctype="multipart/form-data">
    <input type="file" name="audio" accept="audio/*" required style="margin-bottom:10px">
    <button type="submit" class="btn btn-primary">上传替换</button>
  </form>
</div>
<% } %>

<style>
.admin-form { max-width: 600px; margin-top: 20px; }
.form-group { margin-bottom: 16px; }
.form-group label { display: block; font-weight: 600; margin-bottom: 4px; font-size: 14px; color: #555; }
.form-input { width: 100%; padding: 10px 12px; border: 1px solid #ddd; border-radius: 8px; font-size: 14px; }
.form-actions { display: flex; gap: 10px; margin-top: 20px; }
</style>
