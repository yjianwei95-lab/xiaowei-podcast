<div class="admin-bar">
  <h1>📊 后台总览</h1>
  <div class="admin-actions">
    <a href="/admin/podcasts" class="btn">🎙️ 播客管理</a>
    <a href="/admin/visitors" class="btn">👥 访客记录</a>
    <a href="/admin/password" class="btn btn-secondary">🔑 修改密码</a>
    <a href="/admin/logout" class="btn btn-secondary">🚪 退出</a>
  </div>
</div>

<div class="stats-grid">
  <div class="stat-card">
    <span class="stat-icon">🎙️</span>
    <span class="stat-num"><%= stats.totalPodcasts %></span>
    <span class="stat-label">节目总数</span>
  </div>
  <div class="stat-card">
    <span class="stat-icon">▶️</span>
    <span class="stat-num"><%= stats.totalPlayed %></span>
    <span class="stat-label">总播放次数</span>
  </div>
  <div class="stat-card">
    <span class="stat-icon">👥</span>
    <span class="stat-num"><%= stats.totalVisitors %></span>
    <span class="stat-label">总访问量</span>
  </div>
  <div class="stat-card">
    <span class="stat-icon">📅</span>
    <span class="stat-num"><%= stats.todayVisitors %></span>
    <span class="stat-label">今日访问</span>
  </div>
  <div class="stat-card">
    <span class="stat-icon">💾</span>
    <span class="stat-num"><%= (stats.totalSize / 1048576).toFixed(1) %> MB</span>
    <span class="stat-label">总存储</span>
  </div>
</div>

<h2 class="section-title">📌 最近上传</h2>
<div class="admin-table-wrap">
  <table class="admin-table">
    <thead>
      <tr><th>标题</th><th>上传者</th><th>播放</th><th>日期</th><th>状态</th></tr>
    </thead>
    <tbody>
      <% if (recentPodcasts && recentPodcasts.length > 0) {
        recentPodcasts.forEach(function(p) { %>
      <tr>
        <td><a href="/play/<%= p.uuid %>" target="_blank" class="post-link"><%= p.title %></a></td>
        <td><%= p.uploader_name %> <% if (p.uploader_ip) { %><span class="ip-tag"><%= p.uploader_ip %></span><% } %></td>
        <td><%= p.play_count %></td>
        <td class="cell-date"><%= p.created_at.slice(0, 16).replace('T', ' ') %></td>
        <td><span class="badge <%= p.status ? 'badge-on' : 'badge-off' %>"><%= p.status ? '已发布' : '已隐藏' %></span></td>
      </tr>
      <% });
      } else { %>
      <tr><td colspan="5" class="empty-cell">暂无节目</td></tr>
      <% } %>
    </tbody>
  </table>
</div>

<h2 class="section-title">🕐 最近访客</h2>
<div class="admin-table-wrap">
  <table class="admin-table">
    <thead>
      <tr><th>节目</th><th>IP</th><th>浏览器</th><th>访问时间</th></tr>
    </thead>
    <tbody>
      <% if (recentVisitors && recentVisitors.length > 0) {
        recentVisitors.forEach(function(v) { %>
      <tr>
        <td><%= v.podcast_title || '未知节目' %></td>
        <td><span class="ip-tag"><%= v.ip %></span></td>
        <td class="cell-ua"><%= (v.user_agent || '').slice(0, 50) %></td>
        <td class="cell-date"><%= v.visited_at.slice(0, 19).replace('T', ' ') %></td>
      </tr>
      <% });
      } else { %>
      <tr><td colspan="4" class="empty-cell">暂无访问记录</td></tr>
      <% } %>
    </tbody>
  </table>
</div>
