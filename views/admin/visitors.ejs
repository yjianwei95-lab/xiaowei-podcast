<div class="admin-bar">
  <h1>👥 访客记录</h1>
</div>

<h2 class="section-title">📊 按节目统计</h2>
<div class="admin-table-wrap">
  <table class="admin-table">
    <thead><tr><th>节目</th><th>访问次数</th><th>最后访问</th></tr></thead>
    <tbody>
      <% if (byPodcast && byPodcast.length > 0) { byPodcast.forEach(function(b) { %>
        <tr>
          <td><%= b.title %></td>
          <td><strong><%= b.visits || 0 %></strong></td>
          <td class="cell-date"><%= b.last_visit ? b.last_visit.slice(0, 19).replace('T', ' ') : '-' %></td>
        </tr>
      <% }); } else { %>
        <tr><td colspan="3" class="empty-cell">暂无数据</td></tr>
      <% } %>
    </tbody>
  </table>
</div>

<h2 class="section-title">📋 详细访问记录</h2>
<div class="admin-table-wrap">
  <table class="admin-table">
    <thead>
      <tr>
        <th>节目</th>
        <th>IP</th>
        <th>设备</th>
        <th>系统</th>
        <th>浏览器</th>
        <th>访问时间</th>
      </tr>
    </thead>
    <tbody>
      <% if (visitors && visitors.length > 0) { visitors.forEach(function(v) { 
        // 设备显示：手机/电脑 + 品牌型号
        const deviceIcon = v.device_type === 'mobile' ? '📱' : v.device_type === 'tablet' ? '📲' : '💻';
        const deviceLabel = v.device_brand && v.device_model 
          ? `${v.device_brand} ${v.device_model}` 
          : v.device_type === 'desktop' ? '台式/笔记本' : v.device_type || '未知';
        
        // 系统显示
        const osLabel = [v.os, v.os_version].filter(Boolean).join(' ') || '-';
        
        // 浏览器显示
        const browserLabel = [v.browser, v.browser_version].filter(Boolean).join(' ') || '-';
      %>
        <tr>
          <td><%= v.podcast_title || '未知' %></td>
          <td><span class="ip-tag"><%= v.ip %></span></td>
          <td><%= deviceIcon %> <%= deviceLabel %></td>
          <td><%= osLabel %></td>
          <td><%= browserLabel %></td>
          <td class="cell-date"><%= v.visited_at ? v.visited_at.slice(0, 19).replace('T', ' ') : '-' %></td>
        </tr>
      <% }); } else { %>
        <tr><td colspan="6" class="empty-cell">暂无记录</td></tr>
      <% } %>
    </tbody>
  </table>
</div>

<style>
  .admin-table th:nth-child(3),
  .admin-table td:nth-child(3) { max-width: 180px; }
  .admin-table th:nth-child(4),
  .admin-table td:nth-child(4) { max-width: 150px; }
  .admin-table th:nth-child(5),
  .admin-table td:nth-child(5) { max-width: 140px; }
</style>
