<div class="admin-bar">
  <h1>👥 访客记录</h1>
  <div class="admin-actions">
    <a href="/admin" class="btn btn-secondary">← 总览</a>
  </div>
</div>

<h2 class="section-title">📊 按节目统计</h2>
<div class="admin-table-wrap">
  <table class="admin-table">
    <thead>
      <tr><th>节目</th><th>访问次数</th><th>最后访问</th></tr>
    </thead>
    <tbody>
      <% if (byPodcast && byPodcast.length > 0) {
        byPodcast.forEach(function(b) { %>
      <tr>
        <td><a href="/play/<%= b.uuid %>" target="_blank" class="post-link"><%= b.title %></a></td>
        <td><strong><%= b.visits || 0 %></strong></td>
        <td class="cell-date"><%= b.last_visit ? b.last_visit.slice(0, 19).replace('T', ' ') : '-' %></td>
      </tr>
      <% });
      } else { %>
      <tr><td colspan="3" class="empty-cell">暂无数据</td></tr>
      <% } %>
    </tbody>
  </table>
</div>

<h2 class="section-title">📋 详细访问记录</h2>
<div class="admin-table-wrap">
  <table class="admin-table">
    <thead>
      <tr><th>节目</th><th>IP 地址</th><th>来源</th><th>浏览器</th><th>访问时间</th></tr>
    </thead>
    <tbody>
      <% if (visitors && visitors.length > 0) {
        visitors.forEach(function(v) { %>
      <tr>
        <td><%= v.podcast_title || '未知节目' %></td>
        <td><span class="ip-tag"><%= v.ip %></span></td>
        <td><small class="text-muted"><%= v.referer ? v.referer.slice(0, 30) : '直接访问' %></small></td>
        <td class="cell-ua"><small><%= (v.user_agent || '').slice(0, 60) %></small></td>
        <td class="cell-date"><%= v.visited_at.slice(0, 19).replace('T', ' ') %></td>
      </tr>
      <% });
      } else { %>
      <tr><td colspan="5" class="empty-cell">暂无访问记录</td></tr>
      <% } %>
    </tbody>
  </table>
</div>
