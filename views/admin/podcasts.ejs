<div class="admin-bar">
  <h1>🎙️ 播客管理</h1>
</div>

<div class="admin-table-wrap">
  <table class="admin-table">
    <thead>
      <tr><th>标题</th><th>上传者</th><th>IP</th><th>播放</th><th>文件</th><th>日期</th><th>状态</th><th>操作</th></tr>
    </thead>
    <tbody>
      <% if (podcasts && podcasts.length > 0) { podcasts.forEach(function(p) { %>
      <tr>
        <td><%= p.title %></td>
        <td><strong><%= p.uploader_name %></strong><% if (p.uploader_email) { %><br><small><%= p.uploader_email %></small><% } %></td>
        <td><span class="ip-tag"><%= p.uploader_ip %></span></td>
        <td><%= p.play_count %></td>
        <td><small><%= p.original_name %><br><%= (p.file_size / 1048576).toFixed(1) %> MB</small><br><audio src="/uploads/<%= p.filename %>?v=<%= p.created_at ? Date.parse(p.created_at) : '' %>" controls style="width:100px;height:28px;margin-top:4px"></audio></td>
        <td class="cell-date"><%= p.created_at ? new Date(p.created_at).toLocaleDateString('zh-CN', {timeZone:'Asia/Shanghai'}).replace(/\//g, '-') : '-' %></td>
        <td>
          <form method="POST" action="/xiaowei-podcast-admin/toggle/<%= p.id %>" style="display:inline">
            <button class="btn-status <%= p.status ? 'published' : 'draft' %>"><%= p.status ? '已发布' : '已隐藏' %></button>
          </form>
        </td>
        <td class="cell-actions">
          <a href="/audio-editor?podcastId=<%= p.id %>" class="btn-sm" style="margin-right:4px;color:var(--accent)">✂️ 剪音频</a>
          <a href="/xiaowei-podcast-admin/edit/<%= p.id %>" class="btn-sm" style="margin-right:4px">编辑</a>
          <form method="POST" action="/xiaowei-podcast-admin/delete/<%= p.id %>" style="display:inline" onsubmit="return confirm('确定删除《<%= p.title %>》吗？')">
            <button class="btn-sm btn-danger">删除</button>
          </form>
        </td>
      </tr>
      <% }); } else { %>
      <tr><td colspan="8" class="empty-cell">暂无节目</td></tr>
      <% } %>
    </tbody>
  </table>
</div>
