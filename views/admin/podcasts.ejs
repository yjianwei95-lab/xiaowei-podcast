<div class="admin-bar">
  <h1>🎙️ 播客管理</h1>
  <div class="admin-actions">
    <a href="/admin" class="btn btn-secondary">← 总览</a>
    <a href="/upload" class="btn">📤 上传新节目</a>
  </div>
</div>

<div class="admin-table-wrap">
  <table class="admin-table">
    <thead>
      <tr>
        <th>标题</th>
        <th>上传者</th>
        <th>IP / 设备</th>
        <th>播放</th>
        <th>文件</th>
        <th>日期</th>
        <th>状态</th>
        <th>操作</th>
      </tr>
    </thead>
    <tbody>
      <% if (podcasts && podcasts.length > 0) {
        podcasts.forEach(function(p) { %>
      <tr>
        <td><a href="/play/<%= p.uuid %>" target="_blank" class="post-link"><%= p.title %></a></td>
        <td>
          <strong><%= p.uploader_name %></strong>
          <% if (p.uploader_email) { %><br><small><%= p.uploader_email %></small><% } %>
        </td>
        <td>
          <span class="ip-tag"><%= p.uploader_ip %></span>
          <br><small class="text-muted"><%= (p.uploader_agent || '').slice(0, 40) %></small>
        </td>
        <td><%= p.play_count %></td>
        <td><small><%= p.original_name %><br><%= (p.file_size / 1048576).toFixed(1) %> MB</small></td>
        <td class="cell-date"><%= p.created_at.slice(0, 10) %></td>
        <td>
          <form method="POST" action="/admin/toggle/<%= p.id %>" style="display:inline">
            <button class="btn-status <%= p.status ? 'published' : 'draft' %>">
              <%= p.status ? '已发布' : '已隐藏' %>
            </button>
          </form>
        </td>
        <td class="cell-actions">
          <a href="/play/<%= p.uuid %>" class="btn-sm" target="_blank">播放</a>
          <form method="POST" action="/admin/delete/<%= p.id %>" style="display:inline"
                onsubmit="return confirm('确定删除《<%= p.title %>》及其所有访问记录吗？')">
            <button class="btn-sm btn-danger">删除</button>
          </form>
        </td>
      </tr>
      <% });
      } else { %>
      <tr><td colspan="8" class="empty-cell">暂无节目</td></tr>
      <% } %>
    </tbody>
  </table>
</div>
