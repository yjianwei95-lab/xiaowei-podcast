<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' && title ? title + ' - ' : '' %>管理后台</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar">
    <div class="container">
      <a href="/" class="logo">🔐 管理后台</a>
      <div class="nav-links">
        <a href="/xiaowei-podcast-admin">总览</a>
        <a href="/xiaowei-podcast-admin/podcasts">播客管理</a>
        <a href="/xiaowei-podcast-admin/visitors">访客记录</a>
        <a href="/xiaowei-podcast-admin/password">修改密码</a>
        <% if (typeof session !== 'undefined' && session && session.loggedIn) { %>
          <span class="nav-user">👤 <%= session.username || '管理员' %></span>
        <% } %>
        <a href="/xiaowei-podcast-admin/logout" class="nav-logout">退出</a>
      </div>
    </div>
  </nav>

  <main class="container">
    <% if (typeof flash !== 'undefined' && flash) { %>
      <div class="flash <%= flash.category %>"><%= flash.message %></div>
    <% } %>
    <%- content %>
  </main>

  <footer class="footer">
    <div class="container">
      <p>🔐 管理后台 · <a href="http://localhost:3000" target="_blank">前往客户端</a></p>
    </div>
  </footer>
</body>
</html>
