<div class="phone-login-page">
  <div class="phone-login-card">
    <div class="phone-login-header">
      <div class="phone-icon">📱</div>
      <h1>手机号登录</h1>
      <p class="phone-subtitle">输入手机号和密码快速登录</p>
    </div>

    <% if (typeof flash !== 'undefined' && flash) { %>
      <div class="flash <%= flash.category %>"><%= flash.message %></div>
    <% } %>

    <form method="POST" action="/phone-login" class="phone-login-form" id="phoneLoginForm">
      <div class="phone-input-group">
        <span class="phone-prefix">+86</span>
        <input
          type="tel"
          id="phone"
          name="phone"
          class="phone-input"
          maxlength="11"
          placeholder="请输入手机号"
          required
          autocomplete="tel"
          inputmode="numeric"
          pattern="1[3-9]\d{9}"
          value="<%= typeof phone !== 'undefined' ? phone : '' %>"
        >
      </div>

      <div class="form-group">
        <input
          type="password"
          id="password"
          name="password"
          required
          placeholder="请输入密码"
          autocomplete="current-password"
        >
      </div>

      <button type="submit" class="btn btn-full phone-login-btn" id="loginBtn">
        <span class="btn-text">登录</span>
        <span class="btn-loading" style="display:none">登录中...</span>
      </button>
    </form>

    <div class="phone-login-links">
      <p class="auth-hint">还没有账号？<a href="/register">手机号注册</a></p>
    </div>
  </div>
</div>

<script>
document.getElementById('phoneLoginForm').addEventListener('submit', function(e) {
  var phone = document.getElementById('phone').value.replace(/\s/g, '');
  document.getElementById('phone').value = phone;

  if (!/^1[3-9]\d{9}$/.test(phone)) {
    e.preventDefault();
    alert('请输入正确的11位手机号');
    return;
  }

  document.getElementById('loginBtn').querySelector('.btn-text').style.display = 'none';
  document.getElementById('loginBtn').querySelector('.btn-loading').style.display = 'inline';
  document.getElementById('loginBtn').disabled = true;
});
</script>
