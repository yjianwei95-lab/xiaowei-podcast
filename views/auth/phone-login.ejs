<div class="email-login-page">
  <div class="email-login-card">
    <div class="email-login-header">
      <div class="email-icon">📧</div>
      <h1>邮箱登录</h1>
      <p class="email-subtitle">输入邮箱和密码快速登录</p>
    </div>

    <% if (typeof flash !== 'undefined' && flash) { %>
      <div class="flash <%= flash.category %>"><%= flash.message %></div>
    <% } %>

    <form method="POST" action="/phone-login" class="email-login-form" id="emailLoginForm">
      <div class="form-group">
        <input
          type="email"
          id="email"
          name="email"
          class="email-input"
          placeholder="请输入邮箱地址"
          required
          autocomplete="email"
          value="<%= typeof email !== 'undefined' ? email : '' %>"
        >
      </div>

      <div class="form-group">
        <input
          type="password"
          id="password"
          name="password"
          required
          placeholder="请输入密码"
          autocomplete="current-password"
        >
      </div>

      <button type="submit" class="btn btn-full email-login-btn" id="loginBtn">
        <span class="btn-text">登录</span>
        <span class="btn-loading" style="display:none">登录中...</span>
      </button>
    </form>

    <div class="email-login-links">
      <p class="auth-hint">还没有账号？<a href="/register">邮箱注册</a></p>
    </div>
  </div>
</div>

<script>
document.getElementById('emailLoginForm').addEventListener('submit', function(e) {
  var email = document.getElementById('email').value.trim();

  if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
    e.preventDefault();
    alert('请输入正确的邮箱地址');
    return;
  }

  document.getElementById('loginBtn').querySelector('.btn-text').style.display = 'none';
  document.getElementById('loginBtn').querySelector('.btn-loading').style.display = 'inline';
  document.getElementById('loginBtn').disabled = true;
});
</script>
