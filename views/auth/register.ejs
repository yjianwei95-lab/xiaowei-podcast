<div class="login-page">
  <h1>📝 用户注册</h1>
  <% if (typeof flash !== 'undefined' && flash) { %>
    <div class="flash <%= flash.category %>"><%= flash.message %></div>
  <% } %>
  <form method="POST" action="/register" class="auth-form">
    <div class="form-group">
      <label for="email">邮箱 *</label>
      <input type="email" id="email" name="email" placeholder="输入邮箱地址（用于登录）">
      <small style="color:#888;font-size:12px">邮箱和用户名至少填写一项</small>
    </div>
    <div class="form-group">
      <label for="username">用户名</label>
      <input type="text" id="username" name="username" minlength="2" maxlength="20" placeholder="输入用户名">
    </div>
    <div class="form-group">
      <label for="password">密码 *</label>
      <input type="password" id="password" name="password" required minlength="4" placeholder="输入密码（至少4位）">
    </div>
    <div class="form-group">
      <label for="nickname">昵称</label>
      <input type="text" id="nickname" name="nickname" placeholder="选填">
    </div>
    <button type="submit" class="btn btn-full">注册</button>
  </form>
  <p class="auth-hint">已有账号？<a href="/phone-login">邮箱登录</a></p>
  <p class="auth-hint"><a href="/">← 返回首页</a></p>
</div>
