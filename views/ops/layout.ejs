<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' && title ? title + ' · ' : '' %>小伟播客运营系统</title>
  <link rel="stylesheet" href="/ops/css/ops.css">
</head>
<body class="ops-body">
  <div class="ops-shell">
    <!-- 侧边栏 -->
    <aside class="ops-sidebar">
      <div class="ops-logo">🛠️ 运营系统</div>
      <nav class="ops-nav">
        <a class="ops-link" href="/ops" data-match="/ops$"><span class="ico">📊</span>数据看板</a>
        <a class="ops-link" href="/ops/content" data-match="/ops/content"><span class="ico">🎙️</span>内容运营</a>
        <a class="ops-link" href="/ops/announcements" data-match="/ops/announcements"><span class="ico">📢</span>公告与活动</a>
        <a class="ops-link" href="/ops/users" data-match="/ops/users"><span class="ico">👥</span>用户与创作者</a>
        <a class="ops-link" href="/ops/comments" data-match="/ops/comments"><span class="ico">💬</span>评论审核</a>
        <a class="ops-link" href="/ops/export" data-match="/ops/export"><span class="ico">📤</span>数据导出</a>
        <a class="ops-link" href="/ops/settings" data-match="/ops/settings"><span class="ico">⚙️</span>运营账号</a>
      </nav>
      <div class="ops-side-foot">
        <a href="http://localhost:3000" target="_blank" class="ops-ext">↗ 前往前台</a>
      </div>
    </aside>

    <!-- 主区域 -->
    <div class="ops-main">
      <header class="ops-topbar">
        <div class="ops-crumbs"><%= typeof title !== 'undefined' && title ? title : '运营系统' %></div>
        <div class="ops-top-right">
          <% if (typeof session !== 'undefined' && session && session.opsUser) { %>
            <span class="ops-user">👤 <%= session.opsUser %></span>
          <% } %>
          <a href="/ops/logout" class="ops-logout">退出</a>
        </div>
      </header>

      <% if (typeof dbOk !== 'undefined' && !dbOk) { %>
        <div class="ops-banner">⚠️ 数据库未连接（Supabase 环境变量未配置），当前仅显示界面，无真实数据。</div>
      <% } %>

      <% if (typeof flash !== 'undefined' && flash) { %>
        <div class="ops-flash ops-<%= flash.category %>"><%= flash.message %></div>
      <% } %>

      <main class="ops-content">
        <%- content %>
      </main>
    </div>
  </div>

  <script>
    // 高亮当前菜单
    (function () {
      var p = location.pathname;
      document.querySelectorAll('.ops-link').forEach(function (a) {
        var m = a.getAttribute('data-match');
        if (m && (p === m || (m !== '/ops$' && p.indexOf(m) === 0))) a.classList.add('active');
      });
    })();
  </script>
</body>
</html>
