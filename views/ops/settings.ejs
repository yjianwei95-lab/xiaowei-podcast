<div class="ops-page">
  <div class="ops-toolbar">
    <h2 class="ops-h2">⚙️ 运营账号设置</h2>
  </div>

  <div class="ops-card ops-card-narrow">
    <h3 class="ops-card-title">🔑 修改密码</h3>
    <form method="POST" class="ops-form">
      <div class="ops-form-row">
        <label>当前密码</label>
        <input type="password" name="old_password" required>
      </div>
      <div class="ops-form-row">
        <label>新密码</label>
        <input type="password" name="new_password" required minlength="6">
      </div>
      <div class="ops-form-actions">
        <button type="submit" class="ops-btn ops-btn-primary">确认修改</button>
      </div>
    </form>
    <p class="ops-muted">当前登录账号：<b><%= typeof session !== 'undefined' && session ? session.opsUser : '' %></b></p>
  </div>
</div>
