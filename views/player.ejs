<div class="player-page">
  <div class="player-card">
    <div class="player-icon">🎧</div>
    <h1><%= podcast.title %></h1>
    <% if (podcast.description) { %>
    <p class="player-desc"><%= podcast.description %></p>
    <% } %>
    <div class="player-meta">
      <span>👤 <%= podcast.uploader_name %></span>
      <span>▶️ <%= podcast.play_count %> 次播放</span>
      <span>📅 <%= new Date(podcast.created_at).toLocaleDateString('zh-CN', { year:'numeric', month:'2-digit', day:'2-digit' }).replace(/\//g, '-') %></span>
      <span>📦 <%= (podcast.file_size / 1048576).toFixed(1) %> MB</span>
    </div>
    <audio id="audio-player" class="audio-player" controls preload="metadata">
      <source src="<%= audioUrl %>" type="audio/mpeg">
      您的浏览器不支持音频播放
    </audio>
  </div>

  <div class="share-area">
    <h3>🔗 分享这个节目</h3>
    <div class="share-link-box">
      <input type="text" id="share-link" value="<%= req ? req.headers.host : '' %>/play/<%= podcast.uuid %>" readonly>
      <button class="btn" onclick="copyLink()">复制链接</button>
    </div>
  </div>

  <!-- 评论区 -->
  <div class="section-box" id="comments-section">
    <h3>💬 评论区</h3>
    <div id="comments-list"></div>
    <div class="comment-form">
      <input type="text" id="comment-nickname" placeholder="昵称（可选）" maxlength="20">
      <div class="comment-input-wrap">
        <textarea id="comment-content" placeholder="说点什么吧..." maxlength="500" rows="3"></textarea>
        <button class="emoji-btn" onclick="toggleEmojiPicker()" title="选择表情">😀</button>
        <div class="emoji-picker" id="emoji-picker">
          <div class="emoji-title">选择表情</div>
          <div class="emoji-grid" id="emoji-grid"></div>
        </div>
      </div>
      <button class="btn" onclick="submitComment()">发表评论</button>
    </div>
  </div>

  <a href="/" class="back-link">← 返回首页</a>
</div>

<style>
.section-box { background:#f7f7f7; border-radius:12px; padding:16px; margin:16px 0; }
.section-box h3 { margin:0 0 12px 0; font-size:16px; }
.comment-item { background:#fff; border-radius:8px; padding:10px 12px; margin:8px 0; font-size:14px; }
.comment-nickname { font-weight:600; color:#333; }
.comment-time { color:#999; font-size:12px; margin-left:8px; }
.comment-content { margin-top:6px; color:#444; white-space:pre-wrap; word-break:break-all; }
.comment-form input, .comment-form textarea {
.comment-input-wrap textarea { padding-right:40px; }
.emoji-btn { position:absolute; right:6px; top:6px; width:28px; height:28px; border:none; background:transparent; font-size:18px; cursor:pointer; border-radius:4px; display:flex; align-items:center; justify-content:center; }
.emoji-btn:hover { background:#eee; }
.emoji-picker { display:none; position:absolute; right:0; top:36px; width:280px; background:#fff; border:1px solid #ddd; border-radius:10px; box-shadow:0 4px 16px rgba(0,0,0,0.12); z-index:100; padding:8px; }
.emoji-picker.show { display:block; }
.emoji-title { font-size:12px; color:#999; margin-bottom:6px; }
.emoji-grid { display:grid; grid-template-columns:repeat(8, 1fr); gap:2px; max-height:180px; overflow-y:auto; }
.emoji-grid span { font-size:20px; cursor:pointer; padding:4px; border-radius:4px; text-align:center; }
.emoji-grid span:hover { background:#f0f0f0; }
</style>

<script>
var episodeUuid = '<%= podcast.uuid %>';

function copyLink() {
  var input = document.getElementById('share-link');
  input.select(); document.execCommand('copy'); alert('链接已复制！');
}

// 加载评论
function loadComments() {
  fetch('/api/episodes/' + episodeUuid + '/comments').then(r=>r.json()).then(d=>{
    if(!d.success) return;
    var html = '';
    if(d.comments.length===0) html = '<p style="color:#999;text-align:center;">暂无评论，来说两句吧～</p>';
    d.comments.forEach(c=>{
      html += '<div class="comment-item"><span class="comment-nickname">' + escHtml(c.nickname) + '</span><span class="comment-time">' + formatLocalTime(c.created_at) + '</span><div class="comment-content">' + escHtml(c.content) + '</div></div>';
    });
    document.getElementById('comments-list').innerHTML = html;
  });
}

// 提交评论
function submitComment() {
  var nick = document.getElementById('comment-nickname').value;
  var content = document.getElementById('comment-content').value;
  if(!content.trim()) { alert('请输入评论内容'); return; }
  fetch('/api/episodes/' + episodeUuid + '/comments', {
    method:'POST', headers:{'Content-Type':'application/json'},
    body:JSON.stringify({nickname:nick, content:content})
  }).then(r=>r.json()).then(d=>{
    if(d.success) { document.getElementById('comment-content').value=''; loadComments(); }
    else alert(d.message||'提交失败');
  });
}

// 简单 HTML 转义
function escHtml(s) { var d=document.createElement('div'); d.textContent=s; return d.innerHTML; }

// UTC 时间转本地北京时间
function formatLocalTime(iso) {
  if (!iso) return '';
  var d = new Date(iso);
  var y = d.getFullYear();
  var m = String(d.getMonth()+1).padStart(2, '0');
  var day = String(d.getDate()).padStart(2, '0');
  var h = String(d.getHours()).padStart(2, '0');
  var min = String(d.getMinutes()).padStart(2, '0');
  return y + '-' + m + '-' + day + ' ' + h + ':' + min;
}

// ===== 表情选择器 =====
var EMOJIS = ['😀','😁','😂','🤣','😃','😄','😅','😆','😉','😊','😋','😎','😍','😘','🥰','😗','😙','😚','🙂','🤗','🤩','🤔','🤨','😐','😑','😶','🙄','😏','😣','😥','😮','🤐','😯','😪','😫','🥱','😴','😌','😛','😜','😝','🤤','😒','😓','😔','😕','🙃','🤑','😲','☹️','🙁','😖','😞','😟','😤','😢','😭','😦','😧','😨','😩','🤯','😬','😰','😱','🥵','🥶','😳','🤪','😵','😡','😠','🤬','😷','🤒','🤕','🤢','🤮','🤧','😇','🥳','🥺','🤠','🤡','🤥','🤫','🤭','🧐','🤓','👻','💀','👽','🤖','😈','👿','👹','👺','💩','😺','😸','😹','😻','😼','😽','🙀','😿','😾'];

function initEmojiGrid() {
  var grid = document.getElementById('emoji-grid');
  if (!grid || grid.children.length > 0) return;
  EMOJIS.forEach(function(e) {
    var span = document.createElement('span');
    span.textContent = e;
    span.onclick = function() { insertEmoji(e); };
    grid.appendChild(span);
  });
}

function toggleEmojiPicker() {
  var picker = document.getElementById('emoji-picker');
  if (!picker) return;
  if (picker.classList.contains('show')) {
    picker.classList.remove('show');
  } else {
    initEmojiGrid();
    picker.classList.add('show');
  }
}

function insertEmoji(emoji) {
  var ta = document.getElementById('comment-content');
  if (!ta) return;
  var start = ta.selectionStart;
  var end = ta.selectionEnd;
  var val = ta.value;
  ta.value = val.substring(0, start) + emoji + val.substring(end);
  ta.selectionStart = ta.selectionEnd = start + emoji.length;
  ta.focus();
}

// 点击页面其他地方关闭表情面板
document.addEventListener('click', function(e) {
  var picker = document.getElementById('emoji-picker');
  var btn = document.querySelector('.emoji-btn');
  if (picker && !picker.contains(e.target) && e.target !== btn) {
    picker.classList.remove('show');
  }
});

// 页面加载时拉取数据
loadComments();
</script>
