<div class="hero">
  <h1>🎙️ 小伟播客</h1>
  <p class="subtitle">上传你的声音 · 分享你的故事</p>
  <div class="stats-bar">
    <span>📚 <%= stats.totalPodcasts %> 个节目</span>
    <span>▶️ <%= stats.totalPlayed %> 次播放</span>
    <span>👥 <%= stats.totalVisitors %> 次访问</span>
  </div>
  <a href="/upload" class="btn btn-lg">📤 上传你的声音</a>
</div>

<!-- 安装APP引导 -->
<div class="install-banner" id="installBanner" style="display:none; background:linear-gradient(135deg,#4A90D9,#357ABD); color:#fff; padding:16px 20px; border-radius:12px; margin:16px 0; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px">
  <div>
    <strong style="font-size:16px">📱 安装小伟播客APP</strong>
    <p style="margin:4px 0 0; opacity:0.85; font-size:13px">添加到手机主屏幕，像原生APP一样使用</p>
  </div>
  <div style="display:flex; gap:8px">
    <a href="/app" class="btn" style="background:#fff; color:#4A90D9; font-weight:bold; border-radius:8px; padding:8px 16px; text-decoration:none">📥 安装教程</a>
    <button onclick="document.getElementById('installBanner').style.display='none'" style="background:none; border:1px solid rgba(255,255,255,0.5); color:#fff; border-radius:8px; padding:8px 12px; cursor:pointer">✕</button>
  </div>
</div>

<script>
// 检测是否应该显示安装引导（未安装为PWA时显示）
(function() {
  if (window.matchMedia('(display-mode: standalone)').matches) {
    document.getElementById('installBanner').style.display = 'none';
    return;
  }
  // 如果之前关闭过，不再显示
  if (localStorage.getItem('installBannerClosed')) {
    document.getElementById('installBanner').style.display = 'none';
    return;
  }
  document.getElementById('installBanner').style.display = 'flex';
  document.querySelector('#installBanner button').addEventListener('click', function() {
    localStorage.setItem('installBannerClosed', 'true');
  });
})();
</script>

<div class="podcast-grid">
  <% if (podcasts && podcasts.length > 0) {
    podcasts.forEach(function(p) { %>
  <a href="/play/<%= p.uuid %>" class="podcast-card">
    <div class="card-icon">🎧</div>
    <div class="card-body">
      <h3><%= p.title %></h3>
      <p class="card-desc"><%= p.description ? p.description.slice(0, 60) + (p.description.length > 60 ? '...' : '') : '暂无描述' %></p>
      <div class="card-meta">
        <span>👤 <%= p.uploader_name %></span>
        <span>▶️ <%= p.play_count %> 次播放</span>
        <span>📅 <%= p.created_at.slice(0, 10) %></span>
        <span>📦 <%= p.file_size ? (p.file_size / 1048576).toFixed(1) + ' MB' : '未知大小' %></span>
      </div>
    </div>
  </a>
  <% });
  } else { %>
  <div class="empty-state">
    <p>📭 还没有人上传声音</p>
    <p>来做第一个分享者吧！</p>
    <a href="/upload" class="btn">📤 上传声音</a>
  </div>
  <% } %>
</div>
